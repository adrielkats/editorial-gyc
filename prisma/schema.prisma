generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Producto {
  id          Int    @id @default(autoincrement())
  nombre      String
  descripcion String @default("")
  precio      Float  @default(0)
  stock       Int    @default(0)
  imagen      String @default("")
}
